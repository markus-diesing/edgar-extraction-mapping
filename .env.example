# ============================================================
# EDGAR Extraction & PRISM Mapping — environment variables
# ============================================================
# Copy this file to .env and fill in real values.
# The application reads secrets via os.environ (credential_loader.py).
# Never commit .env to version control.

# ------------------------------------------------------------------
# Required — Claude API access
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------
# Required — Microsoft Entra ID (Azure AD) SSO
# Both values come from the EDGAR App Registration in the Azure Portal.
# AZURE_TENANT_ID  = Directory (tenant) ID
# AZURE_CLIENT_ID  = Application (client) ID
# ------------------------------------------------------------------
AZURE_TENANT_ID=0513f305-0dbb-4e4e-b311-98405b8dc943
AZURE_CLIENT_ID=cffd2bfb-d624-4ddb-9850-fe5fe19f6bf5

# ------------------------------------------------------------------
# Optional — PRISM schema source URL
# Default: http://10.10.21.57:30080/api/schema/json (LPA internal)
# Override to point at a different schema server or a local mock.
# ------------------------------------------------------------------
# PRISM_SCHEMA_URL=http://your-schema-server/api/schema/json

# ------------------------------------------------------------------
# Optional — Sectioned extraction (experimental)
# When true, the extractor sends one LLM call per PRISM section
# instead of a single call for the whole schema.
# Tier 0 (registry) and Tier 1 (HTML table) still run first either way.
# Default: false
# ------------------------------------------------------------------
# SECTIONED_EXTRACTION=true
